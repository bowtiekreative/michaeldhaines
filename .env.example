# ── Server ───────────────────────────────────────────────
PORT=3000
NODE_ENV=production
# Public base URL (used for canonical links, sitemap, og:url). No trailing slash.
SITE_URL=https://michaeldhaines.ca

# ── MySQL ────────────────────────────────────────────────
# IMPORTANT: use 127.0.0.1 (not localhost) on Hostinger/CloudLinux —
# Node resolves "localhost" to IPv6 ::1 but the DB grant is on IPv4.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=michaeldhaines

# ── Content API ──────────────────────────────────────────
# Admin credentials used to mint API keys at POST /api/keys
ADMIN_USER=admin
ADMIN_PASSWORD=change-me

# ── Integrations ─────────────────────────────────────────
CALENDLY_URL=https://calendly.com/mikehaines/30min
YOUTUBE_ID=MtfGYrqxvVE
CONTACT_EMAIL=ryan@bowtiekreative.com
